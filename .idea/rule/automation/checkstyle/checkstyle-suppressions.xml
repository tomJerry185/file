<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
    Checkstyle 规则抑制文件
    用于老代码逐步迁移，允许按文件/包/规则粒度抑制增强规则。

    使用方式：
    1. 在 checkstyle-enforced.xml 的 Checker 模块中添加：
       <module name="SuppressionFilter">
         <property name="file" value="${checkstyle.suppressions.file}"/>
       </module>
    2. 或在 Maven 中通过 -Dcheckstyle.suppressions.file 参数指定
    3. 也可以在代码中使用 @SuppressWarnings("checkstyle:ruleId") 注解

    注意：抑制是过渡手段，不是永久方案。每个抑制应有对应的 TODO 和迁移计划。
-->
<suppressions>
    <!-- ==================== 全局抑制（老代码迁移期）==================== -->

    <!-- @Autowired 字段注入：老代码暂时允许，新代码禁止 -->
    <!-- 建议：新文件不加抑制，老文件按包逐步迁移 -->
    <suppress id="autowiredFieldInjection"
              files=".*[\\/](controller|config)[\\/].*\.java"
              message="老代码迁移中"/>

    <!-- ==================== 按文件抑制 ==================== -->

    <!-- 示例：对特定配置类抑制字段注入警告 -->
    <!-- <suppress id="autowiredFieldInjection" files=".*SecurityConfig\.java"/> -->

    <!-- 示例：对特定 Mapper XML 暂时允许 SELECT * -->
    <!-- <suppress id="selectStar" files=".*ComplexReportMapper\.xml"/> -->

    <!-- ==================== 按规则抑制 ==================== -->

    <!-- 如果团队决定暂时不强制某条规则，取消下方注释 -->
    <!-- <suppress id="autowiredFieldInjection"/> -->
    <!-- <suppress id="selectStar"/> -->
    <!-- <suppress id="hardcodedIp"/> -->
</suppressions>
