{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "id": null,
  "uid": "shop-engineering-productivity",
  "title": "Shop 电商工程效能看板",
  "tags": ["shop", "engineering", "productivity", "dora"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "hideControls": false,
  "description": "监控DORA指标、工程质量、效能趋势、安全合规情况",
  "panels": [
    {
      "id": 1,
      "title": "部署频率（次/天）",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_deployment_frequency",
          "refId": "deploymentFrequency",
          "legendFormat": "部署频率"
        }
      ],
      "options": {
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 7 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "变更前置时间（分钟）",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_lead_time",
          "refId": "leadTime",
          "legendFormat": "前置时间"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 1440 }
            ]
          },
          "min": 0,
          "max": 1440
        }
      }
    },
    {
      "id": 3,
      "title": "变更失败率（%）",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_change_failure_rate * 100",
          "refId": "changeFailureRate",
          "legendFormat": "失败率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          },
          "min": 0,
          "max": 50
        }
      }
    },
    {
      "id": 4,
      "title": "服务恢复时间 MTTR（分钟）",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_mttr",
          "refId": "mttr",
          "legendFormat": "MTTR"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 1440 }
            ]
          },
          "min": 0,
          "max": 1440
        }
      }
    },
    {
      "id": 5,
      "title": "任务完成率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_task_completion_rate * 100",
          "refId": "taskCompletionRate",
          "legendFormat": "完成率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 95 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 6,
      "title": "首次成功率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_first_time_success_rate * 100",
          "refId": "firstTimeSuccessRate",
          "legendFormat": "首次成功"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 7,
      "title": "工具调用率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_tool_call_rate * 100",
          "refId": "toolCallRate",
          "legendFormat": "工具调用"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 8,
      "title": "验证覆盖率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_verification_coverage * 100",
          "refId": "verificationCoverage",
          "legendFormat": "验证覆盖"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 100 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 9,
      "title": "规范符合率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_spec_compliance_rate * 100",
          "refId": "specComplianceRate",
          "legendFormat": "规范符合"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 10,
      "title": "同类问题发现率（%）",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dora_stats_similar_issue_discovery_rate * 100",
          "refId": "similarIssueDiscoveryRate",
          "legendFormat": "同类发现"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 11,
      "title": "服务可用性趋势",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "service_availability",
          "refId": "serviceAvailability",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 99,
          "max": 100,
          "custom": { "fillOpacity": 10, "lineWidth": 2, "pointSize": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }
      }
    },
    {
      "id": 12,
      "title": "错误率趋势（5xx）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)",
          "refId": "errorRateTrend",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "pointSize": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 13,
      "title": "P99 延迟趋势",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
          "refId": "p99Latency",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2, "pointSize": 5 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 14,
      "title": "安全漏洞趋势",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(severity{type=\"critical\"}) or vector(0)",
          "refId": "criticalVulnerabilities",
          "legendFormat": "严重漏洞"
        },
        {
          "expr": "count(severity{type=\"high\"}) or vector(0)",
          "refId": "highVulnerabilities",
          "legendFormat": "高危漏洞"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2, "pointSize": 6 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "严重漏洞" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "高危漏洞" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Deployments",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "enable": true,
        "iconColor": "green",
        "expr": "increase(deployment_total[1m]) > 0"
      }
    ]
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["now-1h", "now-6h", "now-12h", "now-24h", "now-7d", "now-30d"]
  }
}
